@startuml
start

:Iniciar automação;
:Buscar pedidos (CEP, peso, dimensões);

:Validar CEP de todos os pedidos;
if (Há CEPs inválidos?) then (Sim)
  :Registrar erros na planilha (CEP inválido);
endif

partition "Correios" {
    :Consultar Correios para todos os pedidos válidos;
    if (Alguma falha?) then (Sim)
        :Registrar erros Correios;
    endif
    :Salvar valores + prazos Correios;
}

partition "Loggi" {
    :Consultar Loggi para todos os pedidos válidos;
    if (Alguma falha?) then (Sim)
        :Registrar erros Loggi;
    endif
    :Salvar valores + prazos Loggi;
}

partition "J&T" {
    :Consultar J&T para todos os pedidos válidos;
    if (Alguma falha?) then (Sim)
        :Registrar erros J&T;
    endif
    :Salvar valores + prazos J&T;
}

:Consolidar resultados de todas as transportadoras;
:Registrar na planilha final;
:Entregar resultado ao usuário;

stop
@enduml
